# Trust Green Wallet — copy to `.env` (do not commit real keys).
# Loaded at runtime via flutter_dotenv (registered as an asset in pubspec.yaml).

TRUSTGREEN_CHAIN_ID=97
TRUSTGREEN_RPC_URL=https://bsc-testnet-rpc.publicnode.com/
TRUSTGREEN_EXPLORER_URL=https://testnet.bscscan.com/
TRUSTGREEN_SYMBOL=TG
TRUSTGREEN_USDT=0xYourUsdtContract
# Either 6 or 18 depending on USDT deployment (default 18).
TRUSTGREEN_USDT_DECIMALS=18

# CoinGecko: keys starting with CG- use Demo API; others use Pro API.
COINGECKO_API_KEY=

# Crypto News API — base URL host only, e.g. https://cryptonews-api.com
NEWS_API_URL=https://cryptonews-api.com
NEWS_API_KEY=
# Optional section: general | alltickers
NEWS_SECTION=general
